{
  "name": "drone-weather-app",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:host": "vite --host 0.0.0.0 --strictPort",
    "build": "tsc -b && vite build",
    "build:mobile": "tsc -b && vite build --mode mobile && npx cap sync",
    "cap:copy": "npx cap copy",
    "cap:sync": "npx cap sync",
    "android": "npx cap open android",
    "android:live": "wait-on http://127.0.0.1:5173 && npx cap run android -l --host localhost --port 5173 --forwardPorts 5173:5173",
    "dev:android": "concurrently -k -s first \"npm:dev:host\" \"npm:android:live\"",
    "ios": "npx cap open ios",
    "preview": "vite preview",
    "test": "vitest run",
    "test:e2e": "playwright test"
  },
  "dependencies": {
    "@capacitor/android": "^8.3.1",
    "@capacitor/core": "^8.3.1",
    "@capacitor/ios": "^8.3.1",
    "@netlify/functions": "^3.1.8",
    "@visx/curve": "^3.12.0",
    "@visx/gradient": "^3.12.0",
    "@visx/group": "^3.12.0",
    "@visx/scale": "^3.12.0",
    "@visx/shape": "^3.12.0",
    "leaflet": "^1.9.4",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "satellite.js": "^7.0.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@capacitor/cli": "^8.3.1",
    "@netlify/vite-plugin": "^2.11.5",
    "@playwright/test": "^1.59.1",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.0",
    "@types/leaflet": "^1.9.21",
    "@types/react": "^19.1.2",
    "@types/react-dom": "^19.1.2",
    "@vitejs/plugin-react": "^4.4.1",
    "concurrently": "^9.2.1",
    "jsdom": "^26.1.0",
    "leaflet": "^1.9.4",
    "netlify-cli": "^25.0.0",
    "typescript": "^5.8.3",
    "vite": "^6.3.5",
    "vitest": "^3.2.4",
    "wait-on": "^9.0.5"
  }
}
